    "node": ">=20.14.0",
    "npm": ">=10.7.0"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@balena/lint": "^9.1.3",
    "@balena/pinejs": "^24.0.0",
    "@balena/sbvr-types": "^11.0.0",
    "@types/chai": "5.2.3",
    "@types/chai-as-promised": "8.0.2",
    "@types/mocha": "10.0.10",
    "@types/sinon": "21.0.1",
    "aws-sdk-client-mock": "4.1.0",
    "chai": "6.2.2",
    "chai-as-promised": "8.0.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
